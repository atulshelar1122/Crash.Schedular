{
  "ConnectionStrings": {
    "Database": "Host=localhost;Port=5433;Database=taskscheduler;Username=admin;Password=admin123;Maximum Pool Size=100"
  },
  "RabbitMQ": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "admin",
    "Password": "admin123",
    "ExchangeName": "task-exchange",
    "PrefetchCount": 10
  },
  "Etcd": {
    "Endpoint": "http://localhost:2379"
  },
  "Scheduler": {
    "PollIntervalSeconds": 5,
    "BatchSize": 100,
    "HeartbeatTimeoutMinutes": 2
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  }
}
